# backend/.htaccess — FIXED
# All RewriteRules now use [L,QSA] so existing query-string params (?id=5, ?page=1, etc.)
# are forwarded correctly to the PHP scripts.

Options -Indexes
Options -MultiViews

RewriteEngine On

# ── Security headers ──────────────────────────────────────────
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# ── CORS preflight ────────────────────────────────────────────
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

Header always set Access-Control-Allow-Origin  "*"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Authorization, Content-Type, Accept"

# ── Auth ──────────────────────────────────────────────────────
RewriteRule ^auth/register$          api/auth/register.php   [L,QSA]
RewriteRule ^auth/login$             api/auth/login.php      [L,QSA]
RewriteRule ^auth/refresh$           api/auth/refresh.php    [L,QSA]

# ── User profile ──────────────────────────────────────────────
RewriteRule ^user/profile$           api/user/profile.php    [L,QSA]

# ── Animals (numeric ID in path → query param) ────────────────
RewriteRule ^animals/([0-9]+)$       api/animals/index.php?id=$1   [L,QSA]
RewriteRule ^animals$                api/animals/index.php          [L,QSA]

# ── Treatments ────────────────────────────────────────────────
RewriteRule ^treatments/([0-9]+)$    api/treatments/index.php?id=$1 [L,QSA]
RewriteRule ^treatments$             api/treatments/index.php       [L,QSA]

# ── Prescriptions ─────────────────────────────────────────────
RewriteRule ^prescriptions$          api/prescriptions/index.php    [L,QSA]

# ── Vaccinations ──────────────────────────────────────────────
RewriteRule ^vaccinations/([0-9]+)$  api/vaccinations/index.php?id=$1 [L,QSA]
RewriteRule ^vaccinations$           api/vaccinations/index.php       [L,QSA]

# ── Reminders ─────────────────────────────────────────────────
RewriteRule ^reminders/([0-9]+)$     api/reminders/index.php?id=$1  [L,QSA]
RewriteRule ^reminders$              api/reminders/index.php         [L,QSA]

# ── Tracking ──────────────────────────────────────────────────
RewriteRule ^tracking/update$        api/tracking/index.php          [L,QSA]
RewriteRule ^tracking/([0-9]+)$      api/tracking/index.php?doctor_id=$1 [L,QSA]

# ── Doctors ───────────────────────────────────────────────────
RewriteRule ^doctors/nearby$         api/doctors/nearby.php          [L,QSA]
RewriteRule ^doctors/profile$        api/doctors/profile.php         [L,QSA]
RewriteRule ^doctors/([0-9]+)$       api/doctors/profile.php?id=$1   [L,QSA]

# ── Inventory ─────────────────────────────────────────────────
RewriteRule ^inventory/([0-9]+)$     api/inventory/index.php?id=$1   [L,QSA]
RewriteRule ^inventory$              api/inventory/index.php          [L,QSA]

# ── Customers ─────────────────────────────────────────────────
# Note: pay sub-route must come BEFORE the generic /{id} rule
RewriteRule ^customers/([0-9]+)/pay$ api/customers/index.php?id=$1&action=pay [L,QSA]
RewriteRule ^customers/([0-9]+)$     api/customers/index.php?id=$1   [L,QSA]
RewriteRule ^customers$              api/customers/index.php          [L,QSA]

# ── Block sensitive files ─────────────────────────────────────
RewriteRule ^config/.*$   - [F,L]
RewriteRule ^\.env$       - [F,L]
RewriteRule ^cron/.*$     - [F,L]
RewriteRule ^test_api\.php$ - [F,L]
